# Copy to keystore.properties (gitignored) for local signed builds:
#   ./gradlew signZip
#
# storeFile   : path to your .jks/.keystore (absolute, or relative to repo root)
# storePassword : keystore password
# keyAlias    : alias of the key inside the keystore
# keyPassword : key password (defaults to storePassword if omitted)
storeFile=rootfix.jks
storePassword=changeit
keyAlias=rootfix
keyPassword=changeit
